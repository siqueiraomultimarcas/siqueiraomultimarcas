# Banco PostgreSQL (Neon)
# Obtenha em: https://neon.tech → New Project → Connection String
DATABASE_URL=postgresql://usuario:senha@ep-xxxx.us-east-2.aws.neon.tech/locadora?sslmode=require

# Chave secreta Flask (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=troque-por-uma-chave-secreta-forte

# Cloudinary — https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=sua_api_secret
